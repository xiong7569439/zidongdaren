# YouTube网红曝光合作系统 - 环境变量模板
# 复制此文件为 .env 并填入实际值

# ============================================
# YouTube Data API配置
# 获取地址: https://console.cloud.google.com/apis/credentials
# ============================================
YOUTUBE_API_KEY=your_youtube_api_key_here

# ============================================
# 邮件发送配置 (SMTP)
# ============================================
# Gmail示例:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password  # 需要使用应用专用密码

# Outlook示例:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=your_email@outlook.com
# SMTP_PASSWORD=your_password

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================
# SendGrid配置（可选）
# 获取地址: https://app.sendgrid.com/settings/api_keys
# ============================================
SENDGRID_API_KEY=

# ============================================
# LLM/AI配置（可选，用于AI邮件生成和谈判回复）
# ============================================

# 选择LLM提供商: openai / anthropic / alibaba / deepseek
LLM_PROVIDER=deepseek

# DeepSeek (推荐 deepseek-chat)
DEEPSEEK_API_KEY=sk-
# LLM_MODEL=deepseek-chat

# 或 OpenAI (推荐 GPT-4o-mini)
# OPENAI_API_KEY=sk-
# LLM_MODEL=gpt-4o-mini

# 或 Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-
# LLM_MODEL=claude-3-haiku-20240307

# 或 阿里云百炼 (推荐 qwen-plus, qwen-max)
# ALIBABA_BAILIAN_API_KEY=sk-
# LLM_PROVIDER=alibaba
# LLM_MODEL=qwen-plus

# 自定义API（兼容OpenAI格式）
# LLM_BASE_URL=https://your-api-endpoint.com/v1

# ============================================
# Notion配置（可选，用于CRM集成）
# 获取地址: https://www.notion.so/my-integrations
# ============================================
NOTION_API_KEY=
NOTION_DATABASE_ID=
